<Window x:Class="Neposedy.WindowsApp.AttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Посещаемость"
        Height="920"
        Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Посещаемость"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#245A4A"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5D7C72"/>
                    <TextBlock Text="Отметка посещаемости детей своей группы"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7C968D"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E3F7EC"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Информация"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2D6856"/>
                        <TextBlock x:Name="tbGroupInfo"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="24"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Дата:"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#2D6856"/>

                <DatePicker x:Name="dpDate"
                            Grid.Column="1"
                            Height="40"
                            SelectedDateChanged="dpDate_SelectedDateChanged"/>

                <TextBlock Grid.Column="2"
                           Text="Ребенок:"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#2D6856"/>

                <ComboBox x:Name="cbChildren"
                          Grid.Column="3"
                          Height="40"
                          Margin="12,0,0,0"
                          SelectionChanged="cbChildren_SelectionChanged"/>

                <TextBlock Grid.Column="4"
                           Text="Статус:"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#2D6856"/>

                <ComboBox x:Name="cbStatus"
                          Grid.Column="5"
                          Height="40"
                          Margin="12,0,0,0"/>

                <TextBlock Grid.Row="1"
                           Text="Комментарий:"
                           VerticalAlignment="Top"
                           Margin="0,16,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#2D6856"/>

                <TextBox x:Name="tbComment"
                         Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Height="44"
                         Margin="0,16,12,0"
                         VerticalContentAlignment="Center"
                         TextWrapping="Wrap"/>

                <StackPanel Grid.Row="1"
                            Grid.Column="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="Сохранить"
                            Width="120"
                            Height="44"
                            Margin="0,0,10,0"
                            Background="#7CC576"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Save_Click"/>

                    <Button Content="Очистить"
                            Width="120"
                            Height="44"
                            Background="#FFD76A"
                            Foreground="#6E5700"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="24"
                Padding="18">
            <DataGrid x:Name="dgAttendance"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      RowHeight="42"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ребенок"
                                        Binding="{Binding ChildName}"
                                        Width="280"/>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding DateText}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Статус"
                                        Binding="{Binding Status}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Комментарий"
                                        Binding="{Binding CommentText}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Воспитатель может добавлять и обновлять посещаемость только детей своей группы."
                           FontSize="14"
                           Foreground="#6A8391"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Обновить"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="#7CC576"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Refresh_Click"/>

            <Button Grid.Column="2"
                    Content="Назад"
                    Height="48"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>