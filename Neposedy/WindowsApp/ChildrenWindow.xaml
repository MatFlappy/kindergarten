<Window x:Class="Neposedy.WindowsApp.ChildrenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Дети"
        Height="1020"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="White" CornerRadius="24" Padding="24" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Управление детьми"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#244B61"/>
                <TextBlock x:Name="tbWelcome"
                           Margin="0,10,0,0"
                           FontSize="16"
                           Foreground="#5F7887"/>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="1" Background="White" CornerRadius="24" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ФИО:"/>
                <TextBox x:Name="tbFullName" Grid.Column="1" Height="35"/>

                <TextBlock Grid.Column="2" Text="Дата рождения:"/>
                <DatePicker x:Name="dpBirthDate" Grid.Column="3" Height="35"/>

                <TextBlock Grid.Row="1" Text="Пол:" Margin="0,10,0,0"/>
                <ComboBox x:Name="cbGender" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Группа:" Margin="0,10,0,0"/>
                <ComboBox x:Name="cbGroups" Grid.Row="1" Grid.Column="3" Height="35" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- TABLE -->
        <Border Grid.Row="2" Background="White" CornerRadius="24" Padding="18">
            <DataGrid x:Name="dgChildren"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="250"/>
                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDateText}" Width="150"/>
                    <DataGridTextColumn Header="Пол" Binding="{Binding Gender}" Width="100"/>
                    <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить" Width="120" Margin="5" Click="Add_Click"/>
            <Button Content="Редактировать" Width="140" Margin="5" Click="Edit_Click"/>
            <Button Content="Удалить" Width="120" Margin="5" Click="Delete_Click"/>
            <Button Content="Обновить" Width="120" Margin="5" Click="Refresh_Click"/>
            <Button Content="Назад" Width="120" Margin="5" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>