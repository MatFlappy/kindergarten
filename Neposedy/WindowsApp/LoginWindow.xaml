<Window x:Class="NeposedyApp.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeposedyApp.Windows"
        mc:Ignorable="d"
        Title="Непоседы — Авторизация"
        Height="720"
        Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4FBFF">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#DFF4FF"
                CornerRadius="28,0,0,28"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Частный детский сад"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#3A6A84"/>
                    <TextBlock Text="«Непоседы»"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="#24506A"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,20,0,20">
                    <Ellipse Width="260"
                             Height="260"
                             Fill="#BEE8FA"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>

                    <Ellipse Width="180"
                             Height="180"
                             Fill="#FFF4B8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Margin="0,70,0,0"/>

                    <Border Width="320"
                            Height="220"
                            Background="White"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            BorderBrush="#B7DCEC"
                            BorderThickness="2">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="☀"
                                           FontSize="40"
                                           HorizontalAlignment="Center"
                                           Foreground="#F2B705"/>
                                <TextBlock Text="Уютная и безопасная"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="#2F4858"
                                           Margin="0,10,0,4"/>
                                <TextBlock Text="система для родителей,"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           Foreground="#56707F"/>
                                <TextBlock Text="воспитателей и администратора"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           Foreground="#56707F"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="2">
                    <Border Background="#FFFFFF"
                            CornerRadius="16"
                            Padding="14"
                            Margin="0,0,0,10">
                        <TextBlock Text="• просмотр детей, групп и воспитателей"
                                   FontSize="15"
                                   Foreground="#355567"/>
                    </Border>

                    <Border Background="#FFFFFF"
                            CornerRadius="16"
                            Padding="14"
                            Margin="0,0,0,10">
                        <TextBlock Text="• учет посещаемости и заметок"
                                   FontSize="15"
                                   Foreground="#355567"/>
                    </Border>

                    <Border Background="#FFFFFF"
                            CornerRadius="16"
                            Padding="14">
                        <TextBlock Text="• объявления и работа с заявками"
                                   FontSize="15"
                                   Foreground="#355567"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="0,28,28,0"
                Padding="36">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Вход в систему"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#244B61"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Введите логин и пароль"
                               FontSize="15"
                               Foreground="#6E8795"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,36,0,16">
                    <TextBlock Text="Логин"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#3F5E6F"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="tbLogin"
                             Height="42"
                             FontSize="15"
                             VerticalContentAlignment="Center"
                             Padding="12,0"
                             BorderBrush="#B7DCEC"
                             BorderThickness="2"
                             Background="#F9FDFF"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,24">
                    <TextBlock Text="Пароль"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#3F5E6F"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="pbPassword"
                                 Height="42"
                                 FontSize="15"
                                 Padding="12,0"
                                 BorderBrush="#B7DCEC"
                                 BorderThickness="2"
                                 Background="#F9FDFF"/>
                </StackPanel>

                <Button Grid.Row="3"
                        Content="Войти"
                        Height="46"
                        Background="#4FA3D9"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Login_Click"/>

                <Border Grid.Row="4"
                        Background="#F5FBFE"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,24,0,0"
                        VerticalAlignment="Top" Height="233">
                    <StackPanel>
                        <TextBlock Text="Роли в системе"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#2E556A"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Администратор — управление данными"
                                   FontSize="14"
                                   Foreground="#5F7887"
                                   Margin="0,0,0,6" TextWrapping="Wrap" Height="40"/>
                        <TextBlock Text="Воспитатель — группа, посещаемость, заметки"
                                   TextWrapping="Wrap" 
                                   FontSize="14"
                                   Foreground="#5F7887"
                                   Margin="0,0,0,6" Height="41"/>
                        <TextBlock Text="Родитель — дети, посещаемость, объявления"
                                   FontSize="14"
                                   TextWrapping="Wrap" 
                                   Foreground="#5F7887" Height="46"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>