<Window x:Class="Neposedy.WindowsApp.AnnouncementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Объявления"
        Height="1020"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Объявления"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#245A4A"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5D7C72"/>
                    <TextBlock Text="Создание объявлений для родителей своей группы"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7C968D"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E3F7EC"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Информация"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2D6856"/>
                        <TextBlock x:Name="tbGroupInfo"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="24"
                Padding="20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Заголовок"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D6856"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="tbTitle"
                             Height="42"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock Text="Текст объявления"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#2D6856"
                               Margin="0,0,0,8"/>
                    <TextBox x:Name="tbDescription"
                             Height="90"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Content="Сохранить"
                            Width="130"
                            Height="44"
                            Margin="0,0,10,0"
                            Background="#7CC576"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Save_Click"/>

                    <Button Content="Очистить"
                            Width="130"
                            Height="44"
                            Background="#FFD76A"
                            Foreground="#6E5700"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="24"
                Padding="18">
            <DataGrid x:Name="dgAnnouncements"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      RowHeight="42"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding PublishDateText}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Заголовок"
                                        Binding="{Binding Title}"
                                        Width="250"/>
                    <DataGridTextColumn Header="Описание"
                                        Binding="{Binding Description}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Воспитатель может публиковать объявления только для своей группы."
                           FontSize="14"
                           Foreground="#6A8391"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Обновить"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="#7CC576"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Refresh_Click"/>

            <Button Grid.Column="2"
                    Content="Назад"
                    Height="48"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>