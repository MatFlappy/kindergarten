<Window x:Class="NeposedyApp.Windows.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Администратор"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Панель администратора"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#244B61"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5F7887"/>
                    <TextBlock Text="Управление основными данными детского сада"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7A92A0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#DFF4FF"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Сегодня в системе"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2E556A"/>
                        <TextBlock Text="• работа с детьми"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#466877"/>
                        <TextBlock Text="• работа с группами"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#466877"/>
                        <TextBlock Text="• работа с заявками"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#466877"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Margin="10" Click="Children_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#CFE7F3" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👦"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Дети"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Добавление, редактирование и распределение детей по группам"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="0" Grid.Column="1" Margin="10" Click="Parents_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#CFE7F3" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👨‍👩‍👧"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Родители"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Просмотр и управление учетными записями родителей и связями с детьми"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="0" Grid.Column="2" Margin="10" Click="Teachers_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#CFE7F3" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👩‍🏫"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Воспитатели"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Сотрудники, их данные и закрепление за группами"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Margin="10" Click="Groups_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#CFE7F3" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🏠"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Группы"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Создание групп, назначение воспитателей и работа с возрастными категориями"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Margin="10" Click="Applications_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#CFE7F3" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📋"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Заявки"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Просмотр, принятие и обработка заявок на поступление"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="2" Margin="10" Click="Logout_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFF4D6" BorderBrush="#F0D27A" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="↩"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Выход"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#7A5A00"/>
                        <TextBlock Text="Вернуться на окно авторизации"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#8B7327"/>
                    </StackPanel>
                </Border>
            </Button>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="20"
                Padding="16"
                Margin="0,20,0,0">
            <TextBlock Text="Администратор управляет детьми, родителями, воспитателями, группами и заявками на поступление."
                       FontSize="14"
                       Foreground="#6A8391"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>