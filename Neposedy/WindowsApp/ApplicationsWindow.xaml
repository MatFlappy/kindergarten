<Window x:Class="Neposedy.WindowsApp.ApplicationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Заявки"
        Height="1020"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Заявки на поступление"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#244B61"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5F7887"/>
                    <TextBlock Text="Просмотр и обработка заявок родителей"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7A92A0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#DFF4FF"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Статистика"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2E556A"/>
                        <TextBlock x:Name="tbCount"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#466877"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="24"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgApplications"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          RowHeight="42"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Родитель" Binding="{Binding ParentFullName}" Width="180"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="140"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding EmailText}" Width="180"/>
                        <DataGridTextColumn Header="Ребенок" Binding="{Binding ChildFullName}" Width="180"/>
                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding ChildBirthDateText}" Width="130"/>
                        <DataGridTextColumn Header="Желаемая группа" Binding="{Binding DesiredGroupText}" Width="160"/>
                        <DataGridTextColumn Header="Комментарий" Binding="{Binding CommentText}" Width="200"/>
                        <DataGridTextColumn Header="Дата заявки" Binding="{Binding ApplicationDateText}" Width="150"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="cbStatus"
                              Height="42"
                              VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Изменить статус"
                            Height="42"
                            Margin="12,0,12,0"
                            Background="#4FA3D9"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="ChangeStatus_Click"/>

                    <Button Grid.Column="2"
                            Content="Удалить"
                            Height="42"
                            Margin="0,0,12,0"
                            Background="#E56B6B"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Delete_Click"/>

                    <Button Grid.Column="3"
                            Content="Обновить"
                            Height="42"
                            Background="#7CC576"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="Refresh_Click"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Администратор может просматривать заявки, менять их статус и удалять записи."
                           FontSize="14"
                           Foreground="#6A8391"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Назад"
                    Height="48"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>