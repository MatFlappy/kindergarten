<Window x:Class="Neposedy.WindowsApp.TeachersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Воспитатели"
        Height="1060"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="24" Padding="24" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Управление воспитателями"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#244B61"/>
                <TextBlock x:Name="tbWelcome"
                           Margin="0,10,0,0"
                           FontSize="16"
                           Foreground="#5F7887"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="24" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ФИО:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbFullName" Grid.Column="1" Height="35"/>

                <TextBlock Grid.Column="2" Text="Логин:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbLogin" Grid.Column="3" Height="35"/>

                <TextBlock Grid.Column="4" Text="Пароль:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPassword" Grid.Column="5" Height="35"/>

                <TextBlock Grid.Row="1" Text="Телефон:" Margin="0,10,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbPhone" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Образование:" Margin="0,10,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbEducation" Grid.Row="1" Grid.Column="3" Height="35" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="Стаж:" Margin="0,10,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbExperienceYears" Grid.Row="1" Grid.Column="5" Height="35" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="24" Padding="18">
            <DataGrid x:Name="dgTeachers"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="240"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="140"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneText}" Width="160"/>
                    <DataGridTextColumn Header="Образование" Binding="{Binding EducationText}" Width="220"/>
                    <DataGridTextColumn Header="Стаж" Binding="{Binding ExperienceYearsText}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить" Width="120" Margin="5" Click="Add_Click"/>
            <Button Content="Редактировать" Width="140" Margin="5" Click="Edit_Click"/>
            <Button Content="Удалить" Width="120" Margin="5" Click="Delete_Click"/>
            <Button Content="Обновить" Width="120" Margin="5" Click="Refresh_Click"/>
            <Button Content="Назад" Width="120" Margin="5" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>