<Window x:Class="Neposedy.WindowsApp.MyGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Моя группа"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Моя группа"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#245A4A"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5D7C72"/>
                    <TextBlock Text="Информация о закрепленной группе и списке детей"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7C968D"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E3F7EC"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Статистика"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2D6856"/>
                        <TextBlock x:Name="tbChildrenCount"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#D2EFE0"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="18"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Название группы"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#4A7868"/>
                    <TextBlock x:Name="tbGroupName"
                               Margin="0,8,0,0"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#2F4858"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D2EFE0"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="18"
                    Margin="10,0">
                <StackPanel>
                    <TextBlock Text="Возраст"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#4A7868"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="tbAgeRange"
                               Margin="0,8,0,0"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#2F4858"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D2EFE0"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="18"
                    Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Описание"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#4A7868"/>
                    <TextBlock x:Name="tbDescription"
                               Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#6A8391"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="24"
                Padding="18">
            <ListBox x:Name="lbChildren"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="lbChildren_MouseDoubleClick"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Width" Value="500"/>
                        <Setter Property="Height" Value="180"/>
                        <Setter Property="Margin" Value="10"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF"
                                BorderBrush="#D2EFE0"
                                BorderThickness="2"
                                CornerRadius="24"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="80"
                                        Height="80"
                                        Background="#EAF9F0"
                                        CornerRadius="40"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center">
                                    <Grid>
                                        <TextBlock Text="🧒"
                                                   FontSize="32"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="{Binding FullName}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#2F4858"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding BirthDateText}"
                                               Margin="0,10,0,0"
                                               FontSize="14"
                                               Foreground="#6A8391"/>

                                    <TextBlock Text="{Binding GenderText}"
                                               Margin="0,6,0,0"
                                               FontSize="14"
                                               Foreground="#6A8391"/>

                                    <Border Background="#EAF9F0"
                                            CornerRadius="10"
                                            Padding="10,6"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Открыть информацию"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2D6856"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Воспитатель видит только свою группу и детей, закрепленных за ней."
                           FontSize="14"
                           Foreground="#6A8391"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Обновить"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="#7CC576"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Refresh_Click"/>

            <Button Grid.Column="2"
                    Content="Назад"
                    Height="48"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>