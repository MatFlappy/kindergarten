<Window x:Class="NeposedyApp.Windows.ParentNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Заметки"
        Height="950"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Заметки воспитателя"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#8A5A00"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#8F7350"/>
                    <TextBlock Text="Просмотр заметок по выбранному ребенку"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#A38A63"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF1C7"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Информация"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#7A5A00"/>
                        <TextBlock x:Name="tbCount"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="20"
                Padding="18"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Выберите ребенка:"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#7A5A00"/>

                <ComboBox x:Name="cbChildren"
                          Grid.Column="1"
                          Height="40"
                          SelectionChanged="cbChildren_SelectionChanged"/>

                <Button Grid.Column="2"
                        Content="Обновить"
                        Height="42"
                        Margin="12,0,12,0"
                        Background="#FFD76A"
                        Foreground="#6E5700"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Refresh_Click"/>

                <Button Grid.Column="3"
                        Content="Назад"
                        Height="42"
                        Background="#F4D98C"
                        Foreground="#6E5700"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Back_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="24"
                Padding="18">
            <DataGrid x:Name="dgNotes"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      RowHeight="42"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding NoteDateText}"
                                        Width="160"/>
                    <DataGridTextColumn Header="Заголовок"
                                        Binding="{Binding TitleText}"
                                        Width="220"/>
                    <DataGridTextColumn Header="Описание"
                                        Binding="{Binding Description}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Воспитатель"
                                        Binding="{Binding TeacherName}"
                                        Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="20"
                Padding="16"
                Margin="0,20,0,0">
            <TextBlock Text="Родитель может просматривать заметки воспитателя по выбранному ребенку."
                       FontSize="14"
                       Foreground="#8B7A6B"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>