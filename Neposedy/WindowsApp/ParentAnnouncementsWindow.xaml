<Window x:Class="NeposedyApp.Windows.ParentAnnouncementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Объявления"
        Height="950"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Объявления группы"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#8A5A00"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#8F7350"/>
                    <TextBlock Text="Просмотр объявлений, опубликованных воспитателем группы"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#A38A63"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF1C7"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Информация"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#7A5A00"/>
                        <TextBlock x:Name="tbCount"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="20"
                Padding="18"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Выберите ребенка:"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#7A5A00"/>

                <ComboBox x:Name="cbChildren"
                          Grid.Column="1"
                          Height="40"
                          SelectionChanged="cbChildren_SelectionChanged"/>

                <Button Grid.Column="2"
                        Content="Обновить"
                        Height="42"
                        Margin="12,0,12,0"
                        Background="#FFD76A"
                        Foreground="#6E5700"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Refresh_Click"/>

                <Button Grid.Column="3"
                        Content="Назад"
                        Height="42"
                        Background="#F4D98C"
                        Foreground="#6E5700"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Back_Click"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="lbAnnouncements"
                     BorderThickness="0"
                     Background="Transparent"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Width" Value="500"/>
                        <Setter Property="Height" Value="250"/>
                        <Setter Property="Margin" Value="10"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                BorderBrush="#F4D98C"
                                BorderThickness="2"
                                CornerRadius="24"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding Title}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#5C4633"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1"
                                           Text="{Binding PublishDateText}"
                                           Margin="0,10,0,12"
                                           FontSize="13"
                                           Foreground="#A38A63"/>

                                <TextBlock Grid.Row="2"
                                           Text="{Binding Description}"
                                           FontSize="15"
                                           Foreground="#8B7A6B"
                                           TextWrapping="Wrap"/>

                                <Border Grid.Row="3"
                                        Background="#FFF6E0"
                                        CornerRadius="10"
                                        Padding="10,6"
                                        Margin="0,14,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding TeacherNameText}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#8A5A00"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="20"
                Padding="16"
                Margin="0,20,0,0">
            <TextBlock Text="Родитель может просматривать объявления группы выбранного ребенка."
                       FontSize="14"
                       Foreground="#8B7A6B"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>