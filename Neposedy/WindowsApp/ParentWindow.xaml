<Window x:Class="NeposedyApp.Windows.ParentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Родитель"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Личный кабинет родителя"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#8A5A00"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#8F7350"/>
                    <TextBlock Text="Информация о детях, группе, посещаемости, заметках и объявлениях"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#A38A63"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF1C7"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Доступно в системе"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#7A5A00"/>
                        <TextBlock Text="• мои дети"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                        <TextBlock Text="• посещаемость"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                        <TextBlock Text="• заметки воспитателя"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                        <TextBlock Text="• объявления группы"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Margin="10" Click="MyChildren_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#F4D98C" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🧒"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Мои дети"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#5C4633"/>
                        <TextBlock Text="Просмотр информации о ребенке, группе и воспитателе"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#8B7A6B"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="0" Grid.Column="1" Margin="10" Click="Attendance_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#F4D98C" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📆"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Посещаемость"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#5C4633"/>
                        <TextBlock Text="История посещаемости ребенка по датам и статусам"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#8B7A6B"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Margin="10" Click="Notes_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#F4D98C" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📘"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Заметки"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#5C4633"/>
                        <TextBlock Text="Комментарии и наблюдения воспитателя о ребенке"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#8B7A6B"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Margin="10" Click="Announcements_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#F4D98C" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📣"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Объявления"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#5C4633"/>
                        <TextBlock Text="Объявления группы, созданные воспитателем"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#8B7A6B"/>
                    </StackPanel>
                </Border>
            </Button>
        </Grid>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Родитель может просматривать только информацию о своих детях: группу, воспитателя, посещаемость, заметки и объявления."
                           FontSize="14"
                           Foreground="#8B7A6B"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Выход"
                    Height="48"
                    Background="#F4D98C"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Logout_Click"/>
        </Grid>
    </Grid>
</Window>