<Window x:Class="NeposedyApp.Windows.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Воспитатель"
        Height="850"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Панель воспитателя"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#245A4A"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#5D7C72"/>
                    <TextBlock Text="Работа с группой, посещаемостью, заметками и объявлениями"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#7C968D"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#E3F7EC"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Основные разделы"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#2D6856"/>
                        <TextBlock Text="• моя группа"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"/>
                        <TextBlock Text="• посещаемость"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"/>
                        <TextBlock Text="• заметки"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"/>
                        <TextBlock Text="• объявления"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#4A7868"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Margin="10" Click="MyGroup_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#D2EFE0" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👧👦"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Моя группа"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Просмотр списка детей своей группы и общей информации о ней"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="0" Grid.Column="1" Margin="10" Click="Attendance_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#D2EFE0" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📅"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Посещаемость"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Отметка присутствия детей, отсутствия и болезни по датам"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Margin="10" Click="Notes_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#D2EFE0" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📝"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Заметки"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Добавление заметок о поведении, успехах и состоянии ребенка"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Margin="10" Click="Announcements_Click" BorderThickness="0" Background="Transparent">
                <Border Background="#FFFFFF" BorderBrush="#D2EFE0" BorderThickness="2" CornerRadius="24" Padding="22">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📢"
                                   FontSize="34"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Объявления"
                                   Margin="0,14,0,6"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#2F4858"/>
                        <TextBlock Text="Создание объявлений для родителей своей группы"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="14"
                                   Foreground="#6A8391"/>
                    </StackPanel>
                </Border>
            </Button>
        </Grid>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="Воспитатель работает только со своей группой: отмечает посещаемость, добавляет заметки и публикует объявления для родителей."
                           FontSize="14"
                           Foreground="#6A8391"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Выход"
                    Height="48"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Logout_Click"/>
        </Grid>
    </Grid>
</Window>