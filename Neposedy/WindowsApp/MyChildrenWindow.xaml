<Window x:Class="NeposedyApp.Windows.MyChildrenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Мои дети"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF6">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Мои дети"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#8A5A00"/>
                    <TextBlock x:Name="tbWelcome"
                               Margin="0,10,0,0"
                               FontSize="16"
                               Foreground="#8F7350"/>
                    <TextBlock Text="Здесь отображается информация о детях, связанных с вашей учетной записью"
                               Margin="0,6,0,0"
                               FontSize="15"
                               Foreground="#A38A63"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFF1C7"
                        CornerRadius="20"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Информация"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#7A5A00"/>
                        <TextBlock x:Name="tbCount"
                                   Margin="0,12,0,0"
                                   FontSize="15"
                                   Foreground="#8E6C19"/>
                        <TextBlock Text="Двойной клик по карточке откроет подробную информацию"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#8E6C19"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="lbChildren"
                     BorderThickness="0"
                     Background="Transparent"
                     MouseDoubleClick="lbChildren_MouseDoubleClick"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Width" Value="500"/>
                        <Setter Property="Height" Value="220"/>
                        <Setter Property="Margin" Value="10"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                BorderBrush="#F4D98C"
                                BorderThickness="2"
                                CornerRadius="24"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="90"
                                        Height="90"
                                        Background="#FFF5D9"
                                        CornerRadius="45"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Center">
                                    <Grid>
                                        <TextBlock Text="🧒"
                                                   FontSize="36"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="{Binding FullName}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#5C4633"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Text="{Binding BirthDateText}"
                                               Margin="0,10,0,0"
                                               FontSize="14"
                                               Foreground="#8B7A6B"/>

                                    <TextBlock Text="{Binding GenderText}"
                                               Margin="0,6,0,0"
                                               FontSize="14"
                                               Foreground="#8B7A6B"/>

                                    <TextBlock Text="{Binding GroupNameText}"
                                               Margin="0,6,0,0"
                                               FontSize="14"
                                               Foreground="#8B7A6B"/>

                                    <TextBlock Text="{Binding TeacherNameText}"
                                               Margin="0,6,0,0"
                                               FontSize="14"
                                               Foreground="#8B7A6B"/>

                                    <Border Background="#FFF6E0"
                                            CornerRadius="10"
                                            Padding="10,6"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Открыть подробнее"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#8A5A00"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="В этом разделе родитель может просматривать информацию о своих детях, группе и воспитателе."
                           FontSize="14"
                           Foreground="#8B7A6B"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Обновить"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Refresh_Click"/>

            <Button Grid.Column="2"
                    Content="Назад"
                    Height="48"
                    Background="#F4D98C"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>