<Window x:Class="Neposedy.WindowsApp.ChildParentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Связь детей и родителей"
        Height="720"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="24" Padding="24" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Связь детей и родителей"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#244B61"/>
                <TextBlock x:Name="tbWelcome"
                           Margin="0,10,0,0"
                           FontSize="16"
                           Foreground="#5F7887"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="24" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Ребенок:" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbChildren" Grid.Column="1" Height="38"/>

                <TextBlock Grid.Column="2" Text="Родитель:" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbParents" Grid.Column="3" Height="38" Margin="12,0,0,0"/>

                <TextBlock Grid.Column="4" Text="Связь:" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbRelation" Grid.Column="5" Height="38" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="24" Padding="18">
            <DataGrid x:Name="dgChildParents"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Ребенок" Binding="{Binding ChildName}" Width="280"/>
                    <DataGridTextColumn Header="Родитель" Binding="{Binding ParentName}" Width="280"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding ParentPhone}" Width="160"/>
                    <DataGridTextColumn Header="Тип связи" Binding="{Binding RelationshipTypeText}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить связь" Width="140" Margin="5" Click="Add_Click"/>
            <Button Content="Удалить связь" Width="140" Margin="5" Click="Delete_Click"/>
            <Button Content="Обновить" Width="120" Margin="5" Click="Refresh_Click"/>
            <Button Content="Назад" Width="120" Margin="5" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>