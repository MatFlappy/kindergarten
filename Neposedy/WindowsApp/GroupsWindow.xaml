<Window x:Class="Neposedy.WindowsApp.GroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Группы"
        Height="1020"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F4FBFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="24" Padding="24" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Управление группами"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#244B61"/>
                <TextBlock x:Name="tbWelcome"
                           Margin="0,10,0,0"
                           FontSize="16"
                           Foreground="#5F7887"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="24" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Название:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbName" Grid.Column="1" Height="35"/>

                <TextBlock Grid.Column="2" Text="Возраст:" VerticalAlignment="Center"/>
                <TextBox x:Name="tbAgeRange" Grid.Column="3" Height="35"/>

                <TextBlock Grid.Row="1" Text="Воспитатель:" Margin="0,10,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbTeachers" Grid.Row="1" Grid.Column="1" Height="35" Margin="0,10,0,0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Описание:" Margin="0,10,0,0" VerticalAlignment="Center"/>
                <TextBox x:Name="tbDescription" Grid.Row="1" Grid.Column="3" Height="35" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="24" Padding="18">
            <DataGrid x:Name="dgGroups"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="220"/>
                    <DataGridTextColumn Header="Возраст" Binding="{Binding AgeRangeText}" Width="150"/>
                    <DataGridTextColumn Header="Воспитатель" Binding="{Binding TeacherName}" Width="250"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding DescriptionText}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Добавить" Width="120" Margin="5" Click="Add_Click"/>
            <Button Content="Редактировать" Width="140" Margin="5" Click="Edit_Click"/>
            <Button Content="Удалить" Width="120" Margin="5" Click="Delete_Click"/>
            <Button Content="Обновить" Width="120" Margin="5" Click="Refresh_Click"/>
            <Button Content="Назад" Width="120" Margin="5" Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>