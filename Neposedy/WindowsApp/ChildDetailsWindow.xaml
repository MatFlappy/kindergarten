<Window x:Class="NeposedyApp.Windows.ChildDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Непоседы — Информация о ребенке"
        Height="620"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FFFDF6"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="110"
                        Height="110"
                        Background="#FFF5D9"
                        CornerRadius="55"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center">
                    <Grid>
                        <TextBlock Text="🧒"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock x:Name="tbFullName"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#8A5A00"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Карточка ребенка"
                               Margin="0,8,0,0"
                               FontSize="15"
                               Foreground="#A38A63"/>

                    <WrapPanel Margin="0,18,0,0">
                        <Border Background="#FFF1C7"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="0,0,10,10">
                            <TextBlock x:Name="tbBirthDate"
                                       FontSize="14"
                                       Foreground="#7A5A00"/>
                        </Border>

                        <Border Background="#FFF1C7"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="0,0,10,10">
                            <TextBlock x:Name="tbGender"
                                       FontSize="14"
                                       Foreground="#7A5A00"/>
                        </Border>

                        <Border Background="#FFF1C7"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="0,0,10,10">
                            <TextBlock x:Name="tbAdmissionDate"
                                       FontSize="14"
                                       Foreground="#7A5A00"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,16,0">
                <Border Background="White"
                        BorderBrush="#F4D98C"
                        BorderThickness="2"
                        CornerRadius="22"
                        Padding="20"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Информация о группе"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#5C4633"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="tbGroup"
                                   FontSize="15"
                                   Foreground="#8B7A6B"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="tbTeacher"
                                   FontSize="15"
                                   Foreground="#8B7A6B"/>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        BorderBrush="#F4D98C"
                        BorderThickness="2"
                        CornerRadius="22"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Медицинская информация"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#5C4633"
                                   Margin="0,0,0,14"/>

                        <TextBlock x:Name="tbMedicalInfo"
                                   FontSize="15"
                                   Foreground="#8B7A6B"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#F4D98C"
                    BorderThickness="2"
                    CornerRadius="22"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Дополнительные сведения"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#5C4633"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="Общие заметки"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#7A5A00"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="tbNotes"
                               FontSize="15"
                               Foreground="#8B7A6B"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,12,0">
                <TextBlock Text="В этом окне родитель может просмотреть полную карточку ребенка."
                           FontSize="14"
                           Foreground="#8B7A6B"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <Button Grid.Column="1"
                    Content="Закрыть"
                    Height="48"
                    Margin="0,0,12,0"
                    Background="#FFD76A"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Close_Click"/>

            <Button Grid.Column="2"
                    Content="Назад"
                    Height="48"
                    Background="#F4D98C"
                    Foreground="#6E5700"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Click="Back_Click"/>
        </Grid>
    </Grid>
</Window>